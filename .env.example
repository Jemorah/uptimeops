# ═══════════════════════════════════════════════════════════════
# UptimeOps Environment Variables — PRODUCTION
# Copy to .env and fill in values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Frontend (VITE_ prefix required for client-side access) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_APP_URL=https://uptimeops.com
VITE_API_URL=https://your-project.supabase.co/functions/v1

# Sentry (error tracking)
VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
VITE_SENTRY_ORG=your-org
VITE_SENTRY_PROJECT=uptimeops

# Stripe (public key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Backend (server-side only, do NOT prefix with VITE_) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Stripe (secret + webhook)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (SMS)
TWILIO_SID=AC...
TWILIO_TOKEN=...
TWILIO_FROM=+1...

# Resend (Email)
RESEND_API_KEY=re_...
FROM_EMAIL=alerts@uptimeops.com

# VM Provider (DigitalOcean)
DIGITALOCEAN_TOKEN=dop_v1_...
DIGITALOCEAN_SSH_KEY_ID=12345678
VM_PROVIDER=digitalocean
VM_SIZE=s-1vcpu-1gb
VM_IMAGE=ubuntu-22-04-x64
VM_REGION=nyc1

# Frontend URL (for link generation)
FRONTEND_URL=https://uptimeops.com

# Logging
LOG_LEVEL=info

# ── ANTIGRAVITY SDK ──
ANTIGRAVITY_API_KEY=ag_...
ANTIGRAVITY_ENDPOINT=https://api.antigravity.ai/v1

# ── Claude API (fallback: GPT-4o) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# ── Sentry Auth Token (build-time only) ──
SENTRY_AUTH_TOKEN=sntrys_...
