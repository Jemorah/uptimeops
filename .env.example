# ═══════════════════════════════════════════════════════════════
# UptimeOps — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Supabase (Frontend) ──
# These are PUBLIC — safe to expose in the browser
VITE_SUPABASE_URL=https://npcopjsqgjvirfjnjemt.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Stripe (Frontend) ──
# Vercel Stripe integration sets these automatically:
# STRIPE_PUBLISHABLE_KEY, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY, STRIPE_SECRET_KEY
# The app reads: VITE_STRIPE_PUBLISHABLE_KEY || NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY

# ── Sentry (Optional) ──
VITE_SENTRY_DSN=https://...@sentry.io/...

# ── App URL ──
VITE_APP_URL=https://uptimeops.com

# ═══════════════════════════════════════════════════════════════
# BELOW ARE BACKEND SECRETS — Set via Supabase CLI, NOT in .env
# ═══════════════════════════════════════════════════════════════

# supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-...
# supabase secrets set OPENAI_API_KEY=sk-proj-...
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# supabase secrets set SENTRY_DSN=https://...@sentry.io/...

# ── How to get each key ──

# ANTHROPIC_API_KEY:  https://console.anthropic.com/ → API Keys
# OPENAI_API_KEY:     https://platform.openai.com/api-keys
# STRIPE_SECRET_KEY:  https://dashboard.stripe.com/apikeys (starts with sk_live_ or sk_test_)
# STRIPE_WEBHOOK_SECRET: Created when you add a webhook endpoint in Stripe Dashboard
# SENTRY_DSN:         https://sentry.io/ → Your Project → Settings → Client Keys (DSN)
