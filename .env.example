# ═══════════════════════════════════════════════════════════════
# UPTIMEOPS ENVIRONMENT VARIABLES
# Copy this file to .env for local development
# Vercel-Supabase integration auto-populates SUPABASE_* vars in production
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (auto-filled by Vercel integration) ───
SUPABASE_URL=https://npcopjsqgjvirfjnjemt.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ───
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ─── Email/SMS (optional) ───
RESEND_API_KEY=re_xxxxxxxx
TWILIO_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE=+1234567890

# ─── AI / Edge Functions (optional) ───
ANTIGRAVITY_API_KEY=ag_xxxxxxxx

# ─── Local Dev Only ───
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
